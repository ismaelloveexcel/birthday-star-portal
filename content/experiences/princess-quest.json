    },
    "missionBriefing": {
      "eyebrow": "Classified · Royal Celebration Briefing",
      "heading": "ATTENTION GUESTS",
      "invitationTemplate": "You are hereby invited to join Princess {{childName}}'s {{age}}th Royal Celebration.",
      "labels": {
        "missionDate": "Celebration Date",
        "launchTime": "Grand Entrance Time",
        "missionBase": "Royal Venue",
        "missionTheme": "Celebration Theme"
      }
    },
    "countdown": {
      "heading": "ROYAL COUNTDOWN",
      "timezoneTemplate": "Timezone: {{timezone}}"
    },
    "rsvp": {
      "heading": "ROYAL RSVP",
      "description": "Confirm your attendance at the royal celebration",
      "whatsappCta": "💌 Confirm via WhatsApp",
      "emailCta": "💌 Confirm via Email",
      "messageTemplate": "Hi! We confirm that we are joining Princess {{childName}}'s royal celebration! 👑",
      "emailSubjectTemplate": "RSVP: Princess {{childName}}'s Royal Celebration"
    },
    "starLog": {
      "eyebrow": "✨ Confidential",
      "heading": "ROYAL SECRET",
