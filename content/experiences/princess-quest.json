      "heading": "ROYAL ACCESS GRANTED",
      "subheading": "Opening the castle gates…"
    },
    "captainReveal": {
      "eyebrow": "Royal Reveal",
      "screenReaderTitleTemplate": "Princess {{childName}}'s {{ageOrdinal}} Royal Celebration",
