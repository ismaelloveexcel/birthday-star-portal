      "quoteTemplate": "“{{funFact2}}”",
      "sealTemplate": "Royal Seal — Princess {{childName}}"
    },
    "viralLoop": {
      "prompt": "✨ Want to create a magical royal celebration for your child?",
      "ctaLabel": "Create your own Birthday Star Portal →",
      "brandFooter": "Wandering Dodo"
    },
    "demoCta": {
      "heading": "Ready to launch your own royal celebration?",
      "ctaLabelTemplate": "Create My Princess Portal — {{price}} →"
    }
  },
  "quiz": {
    "heading": "ROYAL CHALLENGE",
    "description": "Complete your quest to earn Royal Badges",
    "questionLabelTemplate": "Question {{current}} of {{total}}",
    "submitLabel": "Submit Quest",
    "incompleteLabel": "Answer every question to submit.",
    "questions": [
      {
        "id": "turning-age",
        "promptTemplate": "How old is Princess {{childName}} turning?",
        "correctAnswerTemplate": "{{age}}",
        "wrongAnswers": [
          "{{ageMinusOne}}",
          "{{agePlusTwo}}"
        ]
      },
      {
        "id": "favorite-thing",
        "promptTemplate": "What is Princess {{childName}}'s favourite thing?",
        "correctAnswerTemplate": "{{favoriteThing}}",
        "wrongAnswers": [
          "dragons",
          "wizards"
        ],
        "legacyBehavior": {
          "wrongAnswersByFavoriteThing": {
            "dragons": [
              "ponies",
              "wizards"
            ],
            "wizards": [
              "dragons",
              "crowns"
            ]
          }
        }
      },
      {
        "id": "royal-secret",
        "promptTemplate": "Which royal secret belongs to Princess {{childName}}?",
        "correctAnswerTemplate": "{{funFact1}}",
        "wrongAnswers": [
          "once taught a dragon to curtsy",
          "believes she invented glitter"
        ]
      },
      {
        "id": "celebration-location",
        "promptTemplate": "Where is the royal celebration taking place?",
        "correctAnswerTemplate": "{{location}}",
        "wrongAnswers": [
          "Rainbow Castle",
          "Crystal Garden"
        ]
      },
      {
        "id": "celebration-edition",
        "promptTemplate": "Which celebration are you joining today?",
        "correctAnswerTemplate": "Princess Quest Edition",
        "wrongAnswers": [
          "Mermaid Lagoon Edition",
          "Enchanted Forest Edition"
        ]
      }
    ]
  },
  "badge": {
    "eyebrow": "Wandering Dodo · Royal Badge Certificate",
    "heading": "ROYAL QUEST CERTIFICATE",
    "earnedTemplate": "You earned {{score}}/{{totalQuestions}} Royal Badges",
    "missionLineTemplate": "Princess {{childName}}'s Royal Celebration · {{editionName}}",
    "shareLabel": "👑 Share My Badge",
    "copyLabel": "Copy caption",
    "copiedLabel": "Copied!",
    "shareCaptionTemplate": "I earned {{score}}/{{totalQuestions}} Royal Badges at Princess {{childName}}'s Royal Celebration! 👑 {{baseUrl}}",
    "ranks": [
      {
        "minScore": 5,
        "title": "ROYAL COMMANDER",
