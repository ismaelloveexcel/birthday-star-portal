{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExperienceConfig",
  "description": "Schema for a Birthday Star Portal experience edition.",
  "type": "object",
  "required": ["id", "name", "quiz"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique slug for this edition, e.g. space-mission"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name for this edition, e.g. Space Mission Edition"
    },
    "quiz": {
      "type": "object",
      "required": ["questions"],
      "additionalProperties": false,
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["prompt", "correct", "wrong"],
            "additionalProperties": false,
            "properties": {
              "prompt": {
                "type": "string",
                "minLength": 1
              },
              "correct": {
                "type": "string",
                "minLength": 1
              },
              "wrong": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        }
      }
    }
  }
}
