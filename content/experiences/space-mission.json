  "theme": {
    "editionName": "Space Mission Edition",
    "roleName": "Captain",
    "palette": {
      "void": "#050818",
      "nova": "#7c4dff",
      "plasma": "#4fc3f7",
      "gold": "#ffd54f",
      "comet": "#a8b4d4",
      "star": "#f7f9ff",
      "success": "#00e676",
      "danger": "#ff5252"
    },
    "fonts": {
      "display": "font-display",
      "body": "font-sans"
    }
  },
  "sections": [
    {
      "id": "demo-banner",
      "type": "demoBanner",
      "props": {
        "demoOnly": true
      }
    },
    {
